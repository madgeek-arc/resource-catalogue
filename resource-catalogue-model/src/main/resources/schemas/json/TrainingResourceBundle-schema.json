{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Identifiers": {
      "type": "object",
      "properties": {
        "externalId": {
          "type": "string"
        },
        "originalId": {
          "type": "string"
        },
        "pid": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "LoggingInfo": {
      "type": "object",
      "properties": {
        "actionType": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        },
        "userFullName": {
          "type": "string"
        },
        "userRole": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "modifiedAt": {
          "type": "string"
        },
        "modifiedBy": {
          "type": "string"
        },
        "published": {
          "type": "boolean"
        },
        "registeredAt": {
          "type": "string"
        },
        "registeredBy": {
          "type": "string"
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "TrainingResource": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "urls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "alternativePIDs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pid": {
                "type": "string"
              },
              "pidSchema": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "nodePID": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "publishingDate": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "resourceOwner": {
          "type": "string"
        },
        "eoscRelatedServices": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "license": {
          "type": "object",
          "properties": {
            "licenseName": {
              "type": "string"
            },
            "licenseURL": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "accessRights": {
          "type": "string"
        },
        "versionDate": {
          "type": "string"
        },
        "targetGroups": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "learningResourceTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "learningOutcomes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expertiseLevel": {
          "type": "string"
        },
        "contentResourceTypes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "qualifications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "duration": {
          "type": "string"
        },
        "languages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scientificDomains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "scientificDomain": {
                "type": "string"
              },
              "scientificSubdomain": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "creators": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "firstName": {
                "type": "string"
              },
              "lastName": {
                "type": "string"
              },
              "email": {
                "type": "string"
              },
              "role": {
                "type": "string"
              },
              "PIDs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "creatorPID": {
                      "type": "string"
                    },
                    "creatorPIDScheme": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "creatorPID",
                    "creatorPIDScheme"
                  ]
                }
              },
              "affiliations": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "affiliationName": {
                      "type": "string"
                    },
                    "affiliationIdentifier": {
                      "type": "object",
                      "properties": {
                        "creatorID": {
                          "type": "string"
                        },
                        "creatorType": {
                          "type": "string"
                        }
                      },
                      "additionalProperties": false,
                      "required": [
                        "creatorID",
                        "creatorType"
                      ]
                    }
                  },
                  "additionalProperties": false,
                  "required": [
                    "affiliationName"
                  ]
                }
              }
            },
            "additionalProperties": false,
            "required": [
              "firstName",
              "lastName",
              "email"
            ]
          }
        },
        "publicContacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "nodePID",
        "description",
        "publishingDate",
        "type",
        "resourceOwner",
        "accessRights",
        "versionDate",
        "targetGroups",
        "learningOutcomes",
        "expertiseLevel",
        "languages",
        "creators",
        "publicContacts"
      ]
    }
  },
  "type": "object",
  "properties": {
    "active": {
      "type": "boolean"
    },
    "auditState": {
      "type": "string"
    },
    "catalogueId": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "identifiers": {
      "$ref": "#/$defs/Identifiers"
    },
    "latestAuditInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "latestOnboardingInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "latestUpdateInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "legacy": {
      "type": "boolean"
    },
    "loggingInfo": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LoggingInfo"
      }
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "status": {
      "type": "string"
    },
    "suspended": {
      "type": "boolean"
    },
    "trainingResource": {
      "$ref": "#/$defs/TrainingResource"
    }
  },
  "additionalProperties": false
}
