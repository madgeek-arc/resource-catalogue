{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Identifiers": {
      "type": "object",
      "properties": {
        "externalId": {
          "type": "string"
        },
        "originalId": {
          "type": "string"
        },
        "pid": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "LoggingInfo": {
      "type": "object",
      "properties": {
        "actionType": {
          "type": "string"
        },
        "comment": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "userEmail": {
          "type": "string"
        },
        "userFullName": {
          "type": "string"
        },
        "userRole": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "modifiedAt": {
          "type": "string"
        },
        "modifiedBy": {
          "type": "string"
        },
        "published": {
          "type": "boolean"
        },
        "registeredAt": {
          "type": "string"
        },
        "registeredBy": {
          "type": "string"
        },
        "terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "Organisation": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "abbreviation": {
          "type": "string"
        },
        "alternativePIDs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pid": {
                "type": "string"
              },
              "pidSchema": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "nodePID": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "legalEntity": {
          "type": "boolean"
        },
        "legalStatus": {
          "type": "string"
        },
        "hostingLegalEntity": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "logo": {
          "type": "string"
        },
        "multimedia": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "multimediaURL": {
                "type": "string"
              },
              "multimediaName": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "mainContact": {
          "type": "object",
          "properties": {
            "firstName": {
              "type": "string"
            },
            "lastName": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "role": {
              "type": "string"
            },
            "PIDs": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "mainContactPID": {
                    "type": "string"
                  },
                  "mainContactPIDScheme": {
                    "type": "string"
                  }
                },
                "additionalProperties": false,
                "required": [
                  "mainContactPID",
                  "mainContactPIDScheme"
                ]
              }
            },
            "affiliations": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "affiliationName": {
                    "type": "string"
                  },
                  "affiliationIdentifier": {
                    "type": "object",
                    "properties": {
                      "mainContactID": {
                        "type": "string"
                      },
                      "mainContactType": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false,
                    "required": [
                      "mainContactID",
                      "mainContactType"
                    ]
                  }
                },
                "additionalProperties": false,
                "required": [
                  "affiliationName"
                ]
              }
            }
          },
          "additionalProperties": false,
          "required": [
            "firstName",
            "lastName",
            "email"
          ]
        },
        "publicContacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "users": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": {
                "type": "string"
              },
              "userName": {
                "type": "string"
              },
              "userSurname": {
                "type": "string"
              },
              "userEmail": {
                "type": "string"
              }
            },
            "additionalProperties": false,
            "required": [
              "userName",
              "userSurname",
              "userEmail"
            ]
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "abbreviation",
        "nodePID",
        "website",
        "country",
        "legalEntity",
        "description",
        "logo",
        "mainContact",
        "publicContacts"
      ]
    }
  },
  "type": "object",
  "properties": {
    "active": {
      "type": "boolean"
    },
    "auditState": {
      "type": "string"
    },
    "catalogueId": {
      "type": "string"
    },
    "draft": {
      "type": "boolean"
    },
    "identifiers": {
      "$ref": "#/$defs/Identifiers"
    },
    "latestAuditInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "latestOnboardingInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "latestUpdateInfo": {
      "$ref": "#/$defs/LoggingInfo"
    },
    "legacy": {
      "type": "boolean"
    },
    "loggingInfo": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/LoggingInfo"
      }
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    },
    "status": {
      "type": "string"
    },
    "suspended": {
      "type": "boolean"
    },
    "organisation": {
      "$ref": "#/$defs/Organisation"
    }
  },
  "additionalProperties": false
}
