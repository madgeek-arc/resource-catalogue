{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Onboard Resource",
  "id": "resource-onboard-template",
  "description": "Sets the onboard parameters and metadata of the resource via the resource-onboard worker.",
  "version": 1,
  "appliesTo": ["bpmn:Task"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    { "id": "exec", "label": "Execution" }
  ],
  "properties": [
    {
      "label": "Job Type",
      "type": "Hidden",
      "value": "resource-onboard",
      "binding": { "type": "zeebe:taskDefinition:type" },
      "group": "exec"
    },
    {
      "label": "Resource name variable",
      "type": "String",
      "value": "resource",
      "binding": { "type": "zeebe:taskHeader", "key": "resourceName" },
      "constraints": { "notEmpty": true },
      "group": "exec"
    },
    {
      "label": "Status",
      "type": "Dropdown",
      "choices": [
        { "name": "PENDING",  "value": "pending" },
        { "name": "APPROVED", "value": "approved" },
        { "name": "REJECTED", "value": "rejected" }
      ],
      "binding": { "type": "zeebe:taskHeader", "key": "status" },
      "constraints": { "notEmpty": true },
      "group": "exec"
    },
    {
      "label": "Active",
      "type": "Boolean",
      "binding": { "type": "zeebe:taskHeader", "key": "active" },
      "constraints": { "notEmpty": true },
      "group": "exec"
    },
    {
      "label": "Resource (output variable)",
      "type": "String",
      "binding": { "type": "zeebe:output", "source": "=resource" },
      "value": "resource",
      "description": "Process variable name that will hold the fetched resource",
      "constraints": { "notEmpty": true }
    }
  ]
}
