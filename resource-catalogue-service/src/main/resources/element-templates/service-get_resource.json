{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Resource Get",
  "id": "get-resource-template",
  "description": "Fetches a resource from the DB.",
  "version": 2,
  "appliesTo": ["bpmn:Task"],
  "elementType": {
    "value": "bpmn:ServiceTask"
  },
  "groups": [
    { "id": "exec", "label": "Execution" },
    { "id": "io",   "label": "Inputs" }
  ],
  "properties": [
    {
      "label": "Job Type",
      "type": "Hidden",
      "value": "get-resource",
      "binding": { "type": "zeebe:taskDefinition:type" },
      "group": "exec"
    },
    {
      "label": "Resource Variable Name",
      "type": "String",
      "value": "resource",
      "binding": { "type": "zeebe:taskHeader", "key": "resourceName" },
      "constraints": { "notEmpty": true },
      "group": "exec"
    },
    {
      "label": "Resource Type (preset)",
      "description": "Select a fixed type, or choose '(Use expression)' to use the FEEL field below.",
      "type": "Dropdown",
      "choices": [
        { "name": "(Use expression)", "value": "" },
        { "name": "Adapter", "value": "adapter" },
        { "name": "Catalogue", "value": "catalogue" },
        { "name": "Configuration Template", "value": "configuration_template" },
        { "name": "Configuration Template Instance", "value": "configuration_template_instance" },
        { "name": "Datasource", "value": "datasource" },
        { "name": "Deployable Software", "value": "deployable_software" },
        { "name": "Helpdesk", "value": "helpdesk" },
        { "name": "Interoperability Record", "value": "interoperability_record" },
        { "name": "Monitoring", "value": "monitoring" },
        { "name": "Organisation", "value": "organisation" },
        { "name": "Resource Interoperability_record", "value": "resource_interoperability_record" },
        { "name": "Service", "value": "service" },
        { "name": "Training Resource", "value": "training_resource" },
        { "name": "Vocabulary", "value": "vocabulary" }
      ],
      "value": "",
      "binding": { "type": "zeebe:taskHeader", "key": "resourceType" },
      "group": "exec"
    },
    {
      "label": "Resource Type",
      "description": "FEEL expression that evaluates to the resourceType string. Used only if preset is empty. Example: =resourceType",
      "type": "String",
      "feel": "optional",
      "value": "=resourceType",
      "binding": { "type": "zeebe:input", "name": "resourceType" },
      "group": "exec"
    },
    {
      "label": "Id (input)",
      "type": "String",
      "feel": "required",
      "binding": { "type": "zeebe:input", "name": "id" },
      "constraints": { "notEmpty": true },
      "description": "Expression or value that resolves to the resource ID"
    }
  ]
}