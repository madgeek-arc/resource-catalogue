    <bpmn:serviceTask id="Activity_1euokmg" name="Save Resource" zeebe:modelerTemplate="update-resource-template" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-resource" />
        <zeebe:ioMapping>
          <zeebe:input source="=resource" target="resourceName" />
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resourceType" value="service" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0oxlioe</bpmn:incoming>
      <bpmn:outgoing>Flow_0duwala</bpmn:outgoing>
