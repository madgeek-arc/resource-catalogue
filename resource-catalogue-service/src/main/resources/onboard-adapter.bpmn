<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1p43gtl" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.41.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.8.0">
  <bpmn:process id="onboard-adapter" isExecutable="true">
    <bpmn:startEvent id="StartEvent_OnboardResource" name="Start Resource Onboard">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_11flptb</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_1cobda0" name="Check if Catalogue is Approved">
      <bpmn:incoming>Flow_0pjxq7p</bpmn:incoming>
      <bpmn:outgoing>Flow_0r3bpfb</bpmn:outgoing>
      <bpmn:outgoing>Flow_0p1meom</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_0ux95fk" name="Check if Resource is owned by a Catalogue">
      <bpmn:incoming>Flow_11flptb</bpmn:incoming>
      <bpmn:outgoing>Flow_13cl7fo</bpmn:outgoing>
      <bpmn:outgoing>Flow_07azb67</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_1ewiokm" name="Get Catalogue">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="get-catalogue" />
        <zeebe:ioMapping>
          <zeebe:input source="=resource.catalogueId" target="catalogueId" />
        </zeebe:ioMapping>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_13cl7fo</bpmn:incoming>
      <bpmn:outgoing>Flow_0pjxq7p</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_1otm8rv" name="Set Catalogue Value" zeebe:modelerTemplate="set-key-value-script" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=resource" target="resource" />
          <zeebe:input source="catalogueId" target="key" />
          <zeebe:input source="eosc" target="value" />
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
        <zeebe:script expression="=context put(resource, key, value)" resultVariable="resource" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_07azb67</bpmn:incoming>
      <bpmn:outgoing>Flow_1b9ungf</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Activity_1lr0vvx" name="Onboard - Approved" zeebe:modelerTemplate="resource-onboard-template" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="resource-onboard" />
        <zeebe:ioMapping>
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resourceName" value="resource" />
          <zeebe:header key="status" value="approved" />
          <zeebe:header key="active" value="true" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0r3bpfb</bpmn:incoming>
      <bpmn:incoming>Flow_0i7qnvc</bpmn:incoming>
      <bpmn:outgoing>Flow_0skdybj</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0a1sz4u" name="Check Provider Status">
      <bpmn:incoming>Flow_0sojgzr</bpmn:incoming>
      <bpmn:outgoing>Flow_1ff3515</bpmn:outgoing>
      <bpmn:outgoing>Flow_0i7qnvc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Activity_1euokmg" name="Save Resource" zeebe:modelerTemplate="update-resource-template" zeebe:modelerTemplateVersion="2">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="update-resource" />
        <zeebe:ioMapping>
          <zeebe:input source="=resourceType" target="resourceType" />
          <zeebe:input source="=resource" target="resourceName" />
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resourceName" value="resource" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0zjya31</bpmn:incoming>
      <bpmn:outgoing>Flow_1fbt47z</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:scriptTask id="Activity_1vdxr7y" name="Set Audit State" zeebe:modelerTemplate="resource-audit-status-script" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=resource" target="resource" />
          <zeebe:input source="Not audited" target="auditState" />
          <zeebe:output source="=resource" target="resource" />
        </zeebe:ioMapping>
        <zeebe:script expression="=context put(resource, &#34;auditState&#34;, auditState)" resultVariable="resource" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0skdybj</bpmn:incoming>
      <bpmn:outgoing>Flow_0zjya31</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:serviceTask id="Activity_0vagvot" name="Get Provider" zeebe:modelerTemplate="get-resource-template" zeebe:modelerTemplateVersion="2">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="get-resource" />
        <zeebe:ioMapping>
          <zeebe:input source="=resourceType" target="resourceType" />
          <zeebe:input source="=resource.payload.resourceOwner" target="id" />
        </zeebe:ioMapping>
        <zeebe:taskHeaders>
          <zeebe:header key="resourceName" value="provider" />
          <zeebe:header key="resourceType" value="provider" />
        </zeebe:taskHeaders>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1b9ungf</bpmn:incoming>
      <bpmn:outgoing>Flow_0sojgzr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="Event_05bf4c9">
      <bpmn:incoming>Flow_19dxg20</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:scriptTask id="Activity_1a6x7qv" name="Mark Failure" zeebe:modelerTemplate="workflow-result-failure-script" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;FAILURE&#34;" target="status" />
          <zeebe:input source="=403" target="code" />
          <zeebe:input source="=&#34;Provider is not eligible to onboard a resource.&#34;" target="message" />
          <zeebe:output source="=result" target="workflowResult" />
        </zeebe:ioMapping>
        <zeebe:script expression="={ status: status, code: code, message: message }" resultVariable="result" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1ff3515</bpmn:incoming>
      <bpmn:outgoing>Flow_19dxg20</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_0trchkm" name="Mark Success" zeebe:modelerTemplate="workflow-result-success-script" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;SUCCESS&#34;" target="status" />
          <zeebe:input source="=200" target="code" />
          <zeebe:input source="=&#34;Success&#34;" target="message" />
          <zeebe:output source="=result" target="workflowResult" />
        </zeebe:ioMapping>
        <zeebe:script expression="={ status: status, code: code, message: message }" resultVariable="result" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1fbt47z</bpmn:incoming>
      <bpmn:outgoing>Flow_0jgq31p</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:scriptTask id="Activity_101mfzm" name="Mark Failure" zeebe:modelerTemplate="workflow-result-failure-script" zeebe:modelerTemplateVersion="1">
      <bpmn:extensionElements>
        <zeebe:ioMapping>
          <zeebe:input source="=&#34;FAILURE&#34;" target="status" />
          <zeebe:input source="=403" target="code" />
          <zeebe:input source="=&#34;Catalogue is not eligible to onboard a resource.&#34;" target="message" />
          <zeebe:output source="=result" target="workflowResult" />
        </zeebe:ioMapping>
        <zeebe:script expression="={ status: status, code: code, message: message }" resultVariable="result" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0p1meom</bpmn:incoming>
      <bpmn:outgoing>Flow_0f5rjas</bpmn:outgoing>
    </bpmn:scriptTask>
    <bpmn:endEvent id="Event_1dw2hiy">
      <bpmn:incoming>Flow_0f5rjas</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0pjxq7p" sourceRef="Activity_1ewiokm" targetRef="Gateway_1cobda0" />
    <bpmn:sequenceFlow id="Flow_0r3bpfb" name="approved" sourceRef="Gateway_1cobda0" targetRef="Activity_1lr0vvx">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=catalogue.status = "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0p1meom" name="not approved" sourceRef="Gateway_1cobda0" targetRef="Activity_101mfzm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=catalogue = null or catalogue.status != "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_13cl7fo" name="catalogueId is not null" sourceRef="Gateway_0ux95fk" targetRef="Activity_1ewiokm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=resource.catalogueId != null</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_07azb67" name="no catalogue" sourceRef="Gateway_0ux95fk" targetRef="Activity_1otm8rv">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=resource.catalogueId = null or resource.catalogueId = "" or resource.catalogueId = "eosc"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1b9ungf" sourceRef="Activity_1otm8rv" targetRef="Activity_0vagvot" />
    <bpmn:sequenceFlow id="Flow_0skdybj" sourceRef="Activity_1lr0vvx" targetRef="Activity_1vdxr7y" />
    <bpmn:sequenceFlow id="Flow_0sojgzr" sourceRef="Activity_0vagvot" targetRef="Gateway_0a1sz4u" />
    <bpmn:sequenceFlow id="Flow_1ff3515" name="not approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1a6x7qv">
      <bpmn:documentation>The provider is not approved and cannot accept resources.</bpmn:documentation>
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=provider.status != "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0zjya31" sourceRef="Activity_1vdxr7y" targetRef="Activity_1euokmg" />
    <bpmn:sequenceFlow id="Flow_1fbt47z" sourceRef="Activity_1euokmg" targetRef="Activity_0trchkm" />
    <bpmn:sequenceFlow id="Flow_19dxg20" sourceRef="Activity_1a6x7qv" targetRef="Event_05bf4c9" />
    <bpmn:sequenceFlow id="Flow_0f5rjas" sourceRef="Activity_101mfzm" targetRef="Event_1dw2hiy" />
    <bpmn:sequenceFlow id="Flow_0i7qnvc" name="approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1lr0vvx">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=provider.status = "approved"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_11flptb" sourceRef="StartEvent_OnboardResource" targetRef="Gateway_0ux95fk" />
    <bpmn:endEvent id="Event_0m8eqx7">
      <bpmn:incoming>Flow_0jgq31p</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0jgq31p" sourceRef="Activity_0trchkm" targetRef="Event_0m8eqx7" />
  </bpmn:process>
