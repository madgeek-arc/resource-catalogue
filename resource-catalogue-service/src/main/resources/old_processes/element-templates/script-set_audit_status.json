{
  "$schema": "https://unpkg.com/@camunda/zeebe-element-templates-json-schema/resources/schema.json",
  "name": "Set Resource's Audit Status (Script Task)",
  "id": "resource-audit-status-script",
  "description": "Sets the resource's auditState field using a FEEL script task.",
  "version": 1,
  "appliesTo": ["bpmn:Task"],
  "elementType": {
    "value": "bpmn:ScriptTask"
  },
  "groups": [
    { "id": "data", "label": "Data" }
  ],
  "properties": [
    {
      "label": "Script Expression",
      "type": "Hidden",
      "value": "=context put(resource, \"auditState\", auditState)",
      "binding": { "type": "zeebe:script", "property": "expression" },
      "group": "data"
    },
    {
      "label": "Result Variable (internal)",
      "type": "Hidden",
      "value": "resource",
      "binding": { "type": "zeebe:script", "property": "resultVariable" },
      "group": "data"
    },
    {
      "label": "Resource (input mapping source)",
      "description": "FEEL expression that resolves to the resource object (e.g. =resource).",
      "type": "String",
      "value": "=resource",
      "binding": { "type": "zeebe:input", "name": "resource" },
      "constraints": { "notEmpty": true },
      "group": "data"
    },
    {
      "label": "Audit State",
      "type": "Dropdown",
      "choices": [
        { "name": "VALID",  "value": "Valid" },
        { "name": "NOT_AUDITED", "value": "Not audited" },
        { "name": "INVALID_AND_UPDATED", "value": "Invalid and updated" },
        { "name": "INVALID_AND_NOT_UPDATED", "value": "Invalid and not updated" }
      ],
      "binding": { "type": "zeebe:input", "name": "auditState" },
      "constraints": { "notEmpty": true },
      "group": "data"
    },
    {
      "label": "Write back to variable",
      "description": "Process variable name to store the updated resource into (output mapping target).",
      "type": "String",
      "value": "resource",
      "binding": { "type": "zeebe:output", "source": "=resource" },
      "constraints": { "notEmpty": true },
      "group": "data"
    }
  ]
}
