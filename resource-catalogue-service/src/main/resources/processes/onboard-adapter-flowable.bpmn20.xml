<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://flowable.org/bpmn">

  <process id="onboard-adapter-flowable" isExecutable="true">

    <startEvent id="StartEvent_OnboardResource" name="Start Resource Onboard">
      <outgoing>Flow_11flptb</outgoing>
    </startEvent>

    <exclusiveGateway id="Gateway_0ux95fk" name="Check if Resource is owned by a Catalogue">
      <incoming>Flow_11flptb</incoming>
      <outgoing>Flow_13cl7fo</outgoing>
      <outgoing>Flow_07azb67</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_11flptb" sourceRef="StartEvent_OnboardResource" targetRef="Gateway_0ux95fk"/>

    <sequenceFlow id="Flow_13cl7fo" name="catalogueId is not null" sourceRef="Gateway_0ux95fk" targetRef="Activity_1ewiokm">
      <conditionExpression xsi:type="tFormalExpression">${resource['catalogueId'] != null}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_07azb67" name="no catalogue" sourceRef="Gateway_0ux95fk" targetRef="Activity_1otm8rv">
      <conditionExpression xsi:type="tFormalExpression">${resource['catalogueId'] == null || resource['catalogueId'].equals('')}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="Activity_1ewiokm" name="Get Catalogue"
                 flowable:delegateExpression="${getCatalogueDelegate}">
      <incoming>Flow_13cl7fo</incoming>
      <outgoing>Flow_0pjxq7p</outgoing>
    </serviceTask>

    <serviceTask id="Activity_1otm8rv" name="Set Catalogue Value"
                 flowable:delegateExpression="${setKeyValueDelegate}">
      <extensionElements>
        <flowable:field name="variableName" stringValue="resource"/>
        <flowable:field name="key" stringValue="catalogueId"/>
      </extensionElements>
      <incoming>Flow_07azb67</incoming>
      <outgoing>Flow_1b9ungf</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0pjxq7p" sourceRef="Activity_1ewiokm" targetRef="Gateway_1cobda0"/>

    <exclusiveGateway id="Gateway_1cobda0" name="Check if Catalogue is Approved">
      <incoming>Flow_0pjxq7p</incoming>
      <outgoing>Flow_0r3bpfb</outgoing>
      <outgoing>Flow_0p1meom</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_0r3bpfb" name="approved" sourceRef="Gateway_1cobda0" targetRef="Activity_1lr0vvx">
      <conditionExpression xsi:type="tFormalExpression">${catalogue != null &amp;&amp; catalogue['status'] == 'approved'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_0p1meom" name="not approved" sourceRef="Gateway_1cobda0" targetRef="Activity_101mfzm">
      <conditionExpression xsi:type="tFormalExpression">${catalogue == null || catalogue['status'] != 'approved'}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="Activity_101mfzm" name="Mark Failure - Catalogue"
                 flowable:delegateExpression="${markWorkflowResultDelegate}">
      <extensionElements>
        <flowable:field name="status" stringValue="FAILURE"/>
        <flowable:field name="code" stringValue="403"/>
        <flowable:field name="message" stringValue="Catalogue is not eligible to onboard a resource."/>
      </extensionElements>
      <incoming>Flow_0p1meom</incoming>
      <outgoing>Flow_0f5rjas</outgoing>
    </serviceTask>

    <endEvent id="Event_1dw2hiy">
      <incoming>Flow_0f5rjas</incoming>
    </endEvent>

    <sequenceFlow id="Flow_0f5rjas" sourceRef="Activity_101mfzm" targetRef="Event_1dw2hiy"/>

    <serviceTask id="Activity_0vagvot" name="Get Organisation"
                 flowable:delegateExpression="${getOrganisationDelegate}">
      <incoming>Flow_1b9ungf</incoming>
      <outgoing>Flow_0sojgzr</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_1b9ungf" sourceRef="Activity_1otm8rv" targetRef="Activity_0vagvot"/>
    <sequenceFlow id="Flow_0sojgzr" sourceRef="Activity_0vagvot" targetRef="Gateway_0a1sz4u"/>

    <exclusiveGateway id="Gateway_0a1sz4u" name="Check Organisation Status">
      <incoming>Flow_0sojgzr</incoming>
      <outgoing>Flow_1ff3515</outgoing>
      <outgoing>Flow_0i7qnvc</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_1ff3515" name="not approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1a6x7qv">
      <conditionExpression xsi:type="tFormalExpression">${organisation['status'] != 'approved'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_0i7qnvc" name="approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1lr0vvx">
      <conditionExpression xsi:type="tFormalExpression">${organisation['status'] == 'approved'}</conditionExpression>
    </sequenceFlow>

    <serviceTask id="Activity_1a6x7qv" name="Mark Failure - Organisation"
                 flowable:delegateExpression="${markWorkflowResultDelegate}">
      <extensionElements>
        <flowable:field name="status" stringValue="FAILURE"/>
        <flowable:field name="code" stringValue="403"/>
        <flowable:field name="message" stringValue="Organisation is not eligible to onboard a resource."/>
      </extensionElements>
      <incoming>Flow_1ff3515</incoming>
      <outgoing>Flow_19dxg20</outgoing>
    </serviceTask>

    <endEvent id="Event_05bf4c9">
      <incoming>Flow_19dxg20</incoming>
    </endEvent>

    <sequenceFlow id="Flow_19dxg20" sourceRef="Activity_1a6x7qv" targetRef="Event_05bf4c9"/>

    <serviceTask id="Activity_1lr0vvx" name="Onboard - Approved"
                 flowable:delegateExpression="${onboardResourceDelegate}">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="resource"/>
        <flowable:field name="status" stringValue="approved"/>
        <flowable:field name="active" stringValue="true"/>
      </extensionElements>
      <incoming>Flow_0r3bpfb</incoming>
      <incoming>Flow_0i7qnvc</incoming>
      <outgoing>Flow_0skdybj</outgoing>
    </serviceTask>

    <serviceTask id="Activity_1vdxr7y" name="Set Audit State"
                 flowable:delegateExpression="${setKeyValueDelegate}">
      <extensionElements>
        <flowable:field name="variableName" stringValue="resource"/>
        <flowable:field name="key" stringValue="auditState"/>
        <flowable:field name="value" stringValue="Not audited"/>
      </extensionElements>
      <incoming>Flow_0skdybj</incoming>
      <outgoing>Flow_0zjya31</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0skdybj" sourceRef="Activity_1lr0vvx" targetRef="Activity_1vdxr7y"/>

    <serviceTask id="Activity_1euokmg" name="Save Resource"
                 flowable:delegateExpression="${updateResourceDelegate}">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="resource"/>
      </extensionElements>
      <incoming>Flow_0zjya31</incoming>
      <outgoing>Flow_1fbt47z</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0zjya31" sourceRef="Activity_1vdxr7y" targetRef="Activity_1euokmg"/>

    <serviceTask id="Activity_0trchkm" name="Mark Success"
                 flowable:delegateExpression="${markWorkflowResultDelegate}">
      <extensionElements>
        <flowable:field name="status" stringValue="SUCCESS"/>
        <flowable:field name="code" stringValue="200"/>
        <flowable:field name="message" stringValue="Success"/>
      </extensionElements>
      <incoming>Flow_1fbt47z</incoming>
      <outgoing>Flow_0jgq31p</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_1fbt47z" sourceRef="Activity_1euokmg" targetRef="Activity_0trchkm"/>

    <endEvent id="Event_0m8eqx7">
      <incoming>Flow_0jgq31p</incoming>
    </endEvent>

    <sequenceFlow id="Flow_0jgq31p" sourceRef="Activity_0trchkm" targetRef="Event_0m8eqx7"/>

  </process>
