<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://flowable.org/bpmn">

  <process id="onboard-resource-flowable" name="Onboard Resource" isExecutable="true">

    <startEvent id="StartEvent_OnboardResource" name="Start Resource Onboard">
      <outgoing>Flow_1cnsxh6</outgoing>
    </startEvent>

    <exclusiveGateway id="Gateway_0ux95fk" name="Check if Resource is owned by a Catalogue">
      <incoming>Flow_1cnsxh6</incoming>
      <outgoing>Flow_13cl7fo</outgoing>
      <outgoing>Flow_07azb67</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_1cnsxh6" sourceRef="StartEvent_OnboardResource" targetRef="Gateway_0ux95fk"/>

    <sequenceFlow id="Flow_13cl7fo" name="catalogueId is not null" sourceRef="Gateway_0ux95fk" targetRef="Activity_1ewiokm">
      <conditionExpression xsi:type="tFormalExpression">${resource['catalogueId'] != null}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_07azb67" name="no catalogue" sourceRef="Gateway_0ux95fk" targetRef="Activity_1otm8rv">
      <conditionExpression xsi:type="tFormalExpression">${resource['catalogueId'] == null || resource['catalogueId'].equals('') || 'eosc'.equals(resource['catalogueId'])}</conditionExpression>
    </sequenceFlow>

    <!-- Get Catalogue -->
    <serviceTask id="Activity_1ewiokm" name="Get Catalogue"
                 flowable:delegateExpression="${getCatalogueDelegate}">
      <incoming>Flow_13cl7fo</incoming>
      <outgoing>Flow_0pjxq7p</outgoing>
    </serviceTask>

    <!-- Set Catalogue Value (was script task: context put(resource, "catalogueId", "eosc")) -->
    <serviceTask id="Activity_1otm8rv" name="Set Catalogue Value"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.SetKeyValueDelegate">
      <extensionElements>
        <flowable:field name="variableName" stringValue="resource"/>
        <flowable:field name="key" stringValue="catalogueId"/>
        <flowable:field name="value" stringValue="eosc"/>
      </extensionElements>
      <incoming>Flow_07azb67</incoming>
      <outgoing>Flow_1b9ungf</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0pjxq7p" sourceRef="Activity_1ewiokm" targetRef="Gateway_1cobda0"/>

    <exclusiveGateway id="Gateway_1cobda0" name="Check if Catalogue is Approved">
      <incoming>Flow_0pjxq7p</incoming>
      <outgoing>Flow_0r3bpfb</outgoing>
      <outgoing>Flow_0p1meom</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_0r3bpfb" name="approved" sourceRef="Gateway_1cobda0" targetRef="Activity_1lr0vvx">
      <conditionExpression xsi:type="tFormalExpression">${catalogue != null && catalogue['status'] == 'approved'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_0p1meom" sourceRef="Gateway_1cobda0" targetRef="Activity_101mfzm">
      <conditionExpression xsi:type="tFormalExpression">${catalogue == null || catalogue['status'] != 'approved'}</conditionExpression>
    </sequenceFlow>

    <!-- Mark Failure - Catalogue not approved -->
    <serviceTask id="Activity_101mfzm" name="Mark Failure - Catalogue"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.MarkWorkflowResultDelegate">
      <extensionElements>
        <flowable:field name="status" stringValue="FAILURE"/>
        <flowable:field name="code" stringValue="403"/>
        <flowable:field name="message" stringValue="Catalogue is not eligible to onboard a resource."/>
      </extensionElements>
      <incoming>Flow_0p1meom</incoming>
      <outgoing>Flow_07nwkvs</outgoing>
    </serviceTask>

    <endEvent id="Event_1dw2hiy">
      <incoming>Flow_07nwkvs</incoming>
    </endEvent>

    <sequenceFlow id="Flow_07nwkvs" sourceRef="Activity_101mfzm" targetRef="Event_1dw2hiy"/>

    <!-- Get Organisation -->
    <serviceTask id="Activity_0vagvot" name="Get Organisation"
                 flowable:delegateExpression="${getOrganisationDelegate}">
      <incoming>Flow_1b9ungf</incoming>
      <outgoing>Flow_0sojgzr</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_1b9ungf" sourceRef="Activity_1otm8rv" targetRef="Activity_0vagvot"/>
    <sequenceFlow id="Flow_0sojgzr" sourceRef="Activity_0vagvot" targetRef="Gateway_0a1sz4u"/>

    <exclusiveGateway id="Gateway_0a1sz4u" name="Check Organisation Status and Template Status">
      <incoming>Flow_0sojgzr</incoming>
      <outgoing>Flow_0i2qc5x</outgoing>
      <outgoing>Flow_00bwlo7</outgoing>
      <outgoing>Flow_1ff3515</outgoing>
      <outgoing>Flow_1f9jhf2</outgoing>
    </exclusiveGateway>

    <sequenceFlow id="Flow_0i2qc5x" name="Both Approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1lr0vvx">
      <conditionExpression xsi:type="tFormalExpression">${organisation['status'] == 'approved' &amp;&amp; organisation['templateStatus'] == 'approved template'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_00bwlo7" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1y14exa">
      <conditionExpression xsi:type="tFormalExpression">${organisation['templateStatus'] == 'no template status' || organisation['templateStatus'] == 'rejected template'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_1ff3515" name="Organisation not approved" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1a6x7qv">
      <conditionExpression xsi:type="tFormalExpression">${organisation['status'] != 'approved'}</conditionExpression>
    </sequenceFlow>

    <sequenceFlow id="Flow_1f9jhf2" name="Already pending template" sourceRef="Gateway_0a1sz4u" targetRef="Activity_1a6x7qv">
      <conditionExpression xsi:type="tFormalExpression">${organisation['templateStatus'] == 'pending template'}</conditionExpression>
    </sequenceFlow>

    <!-- Onboard - Approve (status=approved, active=true) -->
    <serviceTask id="Activity_1lr0vvx" name="Onboard - Approve"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.OnboardResourceDelegate">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="resource"/>
        <flowable:field name="status" stringValue="approved"/>
        <flowable:field name="active" stringValue="true"/>
      </extensionElements>
      <incoming>Flow_0i2qc5x</incoming>
      <incoming>Flow_0r3bpfb</incoming>
      <outgoing>Flow_0skdybj</outgoing>
    </serviceTask>

    <!-- Set Template Status = "pending template" on organisation -->
    <serviceTask id="Activity_1y14exa" name="Set Template Status"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.SetKeyValueDelegate">
      <extensionElements>
        <flowable:field name="variableName" stringValue="organisation"/>
        <flowable:field name="key" stringValue="templateStatus"/>
        <flowable:field name="value" stringValue="pending template"/>
      </extensionElements>
      <incoming>Flow_00bwlo7</incoming>
      <outgoing>Flow_1yjo50z</outgoing>
    </serviceTask>

    <!-- Save Organisation (resourceName=organisation, resourceType=organisation) -->
    <serviceTask id="Activity_15om8qj" name="Save Organisation"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.UpdateResourceDelegate">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="organisation"/>
        <flowable:field name="resourceType" stringValue="organisation"/>
      </extensionElements>
      <incoming>Flow_1yjo50z</incoming>
      <outgoing>Flow_12ulh07</outgoing>
    </serviceTask>

    <!-- Onboard - Pending (status=pending, active=false) -->
    <serviceTask id="Activity_1vb4twy" name="Onboard - Pending"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.OnboardResourceDelegate">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="resource"/>
        <flowable:field name="status" stringValue="pending"/>
      </extensionElements>
      <incoming>Flow_12ulh07</incoming>
      <outgoing>Flow_0nttkbf</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_1yjo50z" sourceRef="Activity_1y14exa" targetRef="Activity_15om8qj"/>
    <sequenceFlow id="Flow_12ulh07" sourceRef="Activity_15om8qj" targetRef="Activity_1vb4twy"/>

    <!-- Mark Failure - Organisation not eligible -->
    <serviceTask id="Activity_1a6x7qv" name="Mark Failure - Organisation"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.MarkWorkflowResultDelegate">
      <extensionElements>
        <flowable:field name="status" stringValue="FAILURE"/>
        <flowable:field name="code" stringValue="403"/>
        <flowable:field name="message" stringValue="Organisation is not eligible to onboard a resource."/>
      </extensionElements>
      <incoming>Flow_1ff3515</incoming>
      <incoming>Flow_1f9jhf2</incoming>
      <outgoing>Flow_1ut0b35</outgoing>
    </serviceTask>

    <endEvent id="Event_1ele25h">
      <incoming>Flow_1ut0b35</incoming>
    </endEvent>

    <sequenceFlow id="Flow_1ut0b35" sourceRef="Activity_1a6x7qv" targetRef="Event_1ele25h"/>

    <!-- Set Audit State = "Not audited" -->
    <serviceTask id="Activity_1vdxr7y" name="Set Audit State"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.SetKeyValueDelegate">
      <extensionElements>
        <flowable:field name="variableName" stringValue="resource"/>
        <flowable:field name="key" stringValue="auditState"/>
        <flowable:field name="value" stringValue="Not audited"/>
      </extensionElements>
      <incoming>Flow_0nttkbf</incoming>
      <incoming>Flow_0skdybj</incoming>
      <outgoing>Flow_0oxlioe</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0nttkbf" sourceRef="Activity_1vb4twy" targetRef="Activity_1vdxr7y"/>
    <sequenceFlow id="Flow_0skdybj" sourceRef="Activity_1lr0vvx" targetRef="Activity_1vdxr7y"/>

    <!-- Save Resource (resourceType from process var) -->
    <serviceTask id="Activity_1euokmg" name="Save Resource"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.UpdateResourceDelegate">
      <extensionElements>
        <flowable:field name="resourceName" stringValue="resource"/>
      </extensionElements>
      <incoming>Flow_0oxlioe</incoming>
      <outgoing>Flow_0kw3vn7</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0oxlioe" sourceRef="Activity_1vdxr7y" targetRef="Activity_1euokmg"/>

    <!-- Mark Success -->
    <serviceTask id="Activity_0trchkm" name="Mark Success"
                 flowable:class="gr.uoa.di.madgik.resourcecatalogue.onboarding.flowable.delegates.MarkWorkflowResultDelegate">
      <extensionElements>
        <flowable:field name="status" stringValue="SUCCESS"/>
        <flowable:field name="code" stringValue="200"/>
        <flowable:field name="message" stringValue="Success"/>
      </extensionElements>
      <incoming>Flow_0kw3vn7</incoming>
      <outgoing>Flow_0ealddc</outgoing>
    </serviceTask>

    <sequenceFlow id="Flow_0kw3vn7" sourceRef="Activity_1euokmg" targetRef="Activity_0trchkm"/>

    <endEvent id="Event_05bf4c9">
      <incoming>Flow_0ealddc</incoming>
    </endEvent>

    <sequenceFlow id="Flow_0ealddc" sourceRef="Activity_0trchkm" targetRef="Event_05bf4c9"/>

  </process>
</definitions>
