<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- ===== Elasticsearch client JARs (7.x) =====
         CVEs target the Elasticsearch server, not the Java REST/transport client.
         False positives caused by NVD/CPE mismatches on the org.elasticsearch groupId.
         One suppression per CPE vendor variant (elastic vs elasticsearch). -->

    <!-- aggs-matrix-stats-client (sha1-matched) -->
    <suppress>
        <notes><![CDATA[ file name: aggs-matrix-stats-client-7.17.24.jar ]]></notes>
        <sha1>13780b09e473db3cdc1131ad747c9ff2c527b552</sha1>
        <cpe>cpe:/a:elastic:elasticsearch</cpe>
    </suppress>

    <!-- All org.elasticsearch/* JARs — suppress both CPE vendor variants -->
    <suppress>
        <notes><![CDATA[
            org.elasticsearch/* client JARs (elasticsearch, elasticsearch-core, elasticsearch-cli,
            elasticsearch-geo, etc.) — CVEs target the server product. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch/.*@.*$</packageUrl>
        <cpe>cpe:/a:elastic:elasticsearch</cpe>
    </suppress>
    <suppress>
        <notes><![CDATA[
            org.elasticsearch/* client JARs — CVEs target the server product. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch/.*@.*$</packageUrl>
        <cpe>cpe:/a:elasticsearch:elasticsearch</cpe>
    </suppress>

    <!-- All org.elasticsearch.plugin/* client JARs -->
    <suppress>
        <notes><![CDATA[
            org.elasticsearch.plugin/* client JARs (lang-mustache-client, mapper-extras-client,
            parent-join-client, rank-eval-client, etc.) — CVEs target the server. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch\.plugin/.*@.*$</packageUrl>
        <cpe>cpe:/a:elastic:elasticsearch</cpe>
    </suppress>
    <suppress>
        <notes><![CDATA[
            org.elasticsearch.plugin/* client JARs — CVEs target the server. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch\.plugin/.*@.*$</packageUrl>
        <cpe>cpe:/a:elasticsearch:elasticsearch</cpe>
    </suppress>

    <!-- Elasticsearch REST client 8.x -->
    <suppress>
        <notes><![CDATA[
            elasticsearch-rest-client: pure HTTP client library.
            CVEs target the Elasticsearch server product. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch\.client/.*@.*$</packageUrl>
        <cpe>cpe:/a:elastic:elasticsearch</cpe>
    </suppress>
    <suppress>
        <notes><![CDATA[
            elasticsearch-rest-client: pure HTTP client library.
            CVEs target the Elasticsearch server product. False positive.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.elasticsearch\.client/.*@.*$</packageUrl>
        <cpe>cpe:/a:elasticsearch:elasticsearch</cpe>
    </suppress>

    <!-- ===== Guava =====
         CVE-2018-10237: Unbounded memory allocation via deserialization in AtomicDoubleArray.
         CVE-2020-8908: Path traversal via Files.createTempDir() on Unix.
         CVE-2023-2976: Predictable temporary file creation on Unix.
         guava-16.0.1 is a transitive dependency (pulled in by legacy libraries).
         The application does not use the affected APIs directly. -->
    <suppress>
        <notes><![CDATA[
            guava-16.0.1.jar: transitive dependency. CVE-2018-10237, CVE-2020-8908, CVE-2023-2976
            affect APIs not used by this application. Suppressed pending upstream upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava@.*$</packageUrl>
        <cve>CVE-2018-10237</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            guava-16.0.1.jar: transitive dependency. CVE-2020-8908 (temp dir creation).
            Not used by this application. Suppressed pending upstream upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava@.*$</packageUrl>
        <cve>CVE-2020-8908</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            guava-16.0.1.jar: transitive dependency. CVE-2023-2976 (temp file predictability).
            Not used by this application. Suppressed pending upstream upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.guava/guava@.*$</packageUrl>
        <cve>CVE-2023-2976</cve>
    </suppress>

    <!-- ===== jackson-mapper-asl =====
         CVE-2019-10172: Unsafe deserialization in EOL jackson 1.x.
         Transitive dependency; not used for untrusted input deserialization. -->
    <suppress>
        <notes><![CDATA[
            jackson-mapper-asl-1.9.13.jar: EOL transitive dependency.
            CVE-2019-10172: not used for untrusted input. Suppressed pending upstream upgrade.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.codehaus\.jackson/jackson-mapper-asl@.*$</packageUrl>
        <cve>CVE-2019-10172</cve>
    </suppress>

    <!-- ===== log4j (all artifacts) =====
         CVE-2025-68161: Affects log4j 2.x artifacts (log4j-core, log4j-api, log4j-jul, etc.).
         Suppressed as a temporary measure. Monitor https://logging.apache.org/log4j/2.x/security.html -->
    <suppress>
        <notes><![CDATA[
            All org.apache.logging.log4j/* JARs: CVE-2025-68161.
            Suppressed pending a patched log4j release.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/.*@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>

    <!-- ===== matomo-java-tracker =====
         CVE-2023-6923: Targets the Matomo PHP web analytics application, not the Java client.
         False positive — CPE matches on product name "matomo"/"piwik" regardless of ecosystem. -->
    <suppress>
        <notes><![CDATA[
            matomo-java-tracker-core-3.0.6.jar: CVE-2023-6923 affects the Matomo PHP server,
            not the Java tracker client. False positive due to CPE/package name overlap.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.piwik\.java\.tracking/.*@.*$</packageUrl>
        <cve>CVE-2023-6923</cve>
    </suppress>

    <!-- ===== swagger-ui / DOMPurify =====
         CVE-2025-15599, CVE-2026-0540: Vulnerabilities in DOMPurify bundled inside
         swagger-ui JAR (swagger-ui-bundle.js, swagger-ui-es-bundle.js).
         Suppressed pending a swagger-ui release that ships a patched DOMPurify.
         Suppressions cover both the Maven JAR artifact and the JavaScript sub-component. -->
    <suppress>
        <notes><![CDATA[
            swagger-ui (maven JAR): DOMPurify CVE-2025-15599 in bundled JS.
            Suppressed pending swagger-ui upgrade with patched DOMPurify.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.webjars/swagger-ui@.*$</packageUrl>
        <cve>CVE-2025-15599</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            swagger-ui (maven JAR): DOMPurify CVE-2026-0540 in bundled JS.
            Suppressed pending swagger-ui upgrade with patched DOMPurify.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.webjars/swagger-ui@.*$</packageUrl>
        <cve>CVE-2026-0540</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            DOMPurify bundled inside swagger-ui JAR (swagger-ui-bundle.js / swagger-ui-es-bundle.js).
            CVE-2025-15599: suppressed pending swagger-ui upgrade with patched DOMPurify.
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@.*$</packageUrl>
        <cve>CVE-2025-15599</cve>
    </suppress>
    <suppress>
        <notes><![CDATA[
            DOMPurify bundled inside swagger-ui JAR (swagger-ui-bundle.js / swagger-ui-es-bundle.js).
            CVE-2026-0540: suppressed pending swagger-ui upgrade with patched DOMPurify.
        ]]></notes>
        <packageUrl regex="true">^pkg:javascript/DOMPurify@.*$</packageUrl>
        <cve>CVE-2026-0540</cve>
    </suppress>

</suppressions>
